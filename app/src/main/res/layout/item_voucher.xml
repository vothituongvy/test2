<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="16dp"
    android:layout_marginVertical="8dp"
    app:cardBackgroundColor="#FFFFFF"
    app:cardCornerRadius="12dp"
    app:cardElevation="3dp"
    app:strokeColor="#EEEEEE"
    app:strokeWidth="1dp">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingBottom="12dp"> <LinearLayout
        android:id="@+id/layoutIcon"
        android:layout_width="85dp"
        android:layout_height="0dp"
        android:background="#FFF3E0"
        android:gravity="center"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <ImageView
            android:id="@+id/imgVoucherType"
            android:layout_width="45dp"
            android:layout_height="45dp"
            android:src="@drawable/icon_voucher2"
            app:tint="#FF5722" />
    </LinearLayout>

        <View
            android:id="@+id/viewDivider"
            android:layout_width="1dp"
            android:layout_height="0dp"
            android:layout_marginVertical="10dp"
            android:alpha="0.2"
            android:background="@android:color/darker_gray"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toEndOf="@+id/layoutIcon"
            app:layout_constraintTop_toTopOf="parent" />

        <Button
            android:id="@+id/btn_dungngay"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:layout_marginEnd="12dp"
            android:layout_marginBottom="4dp"
            android:backgroundTint="#FF5722"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            android:paddingHorizontal="10dp"
            android:text="Dùng ngay"
            android:textAllCaps="false"
            android:textColor="@android:color/white"
            android:textSize="11sp"
            app:cornerRadius="18dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <TextView
            android:id="@+id/tvVoucherName"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:layout_marginTop="12dp"
            android:layout_marginEnd="8dp"
            android:ellipsize="end"
            android:maxLines="1"
            android:textColor="#212121"
            android:textSize="16sp"
            android:textStyle="bold"
            tools:text="Giảm giá 10.000đ"
            app:layout_constraintEnd_toStartOf="@+id/btn_dungngay"
            app:layout_constraintStart_toEndOf="@+id/viewDivider"
            app:layout_constraintTop_toTopOf="parent" />

        <TextView
            android:id="@+id/tvVoucherDetail"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:layout_marginEnd="8dp"
            android:layout_marginBottom="8dp"
            android:textColor="#757575"
            android:textSize="13sp"
            tools:text="Áp dụng cho mọi đơn hàng "
            app:layout_constraintBottom_toTopOf="@+id/tvQuantity"
            app:layout_constraintEnd_toStartOf="@+id/btn_dungngay"
            app:layout_constraintStart_toStartOf="@+id/tvVoucherName"
            app:layout_constraintTop_toBottomOf="@id/tvVoucherName"
            app:layout_constraintVertical_bias="0.0" />

        <TextView
            android:id="@+id/tvQuantity"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:background="#FBE9E7"
            android:paddingHorizontal="6dp"
            android:paddingVertical="2dp"
            android:textColor="#FF5722"
            android:textSize="11sp"
            android:textStyle="bold"
            tools:text="Số lượng: 1"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="@+id/tvVoucherName" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</com.google.android.material.card.MaterialCardView>