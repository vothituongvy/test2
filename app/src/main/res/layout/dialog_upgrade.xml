<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#99000000"> <LinearLayout
    android:layout_width="320dp"
    android:layout_height="wrap_content"
    android:layout_gravity="center"
    android:orientation="vertical"
    android:background="@drawable/bg_dialog_white"
    android:padding="24dp"
    android:elevation="8dp">

    <ImageView
        android:id="@+id/btnClose"
        android:layout_width="24dp"
        android:layout_height="22dp"
        android:layout_gravity="end"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:padding="4dp"
        android:src="@drawable/icon_thoat2"
        app:tint="#FF5722" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="ƯU ĐÃI ĐẶC BIỆT"
        android:textSize="20sp"
        android:textStyle="bold"
        android:textColor="#FF5722"
        android:gravity="center"
        android:letterSpacing="0.05"/>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Xem video để nhận ngay 1 xu hoặc nâng cấp VIP để hưởng đặc quyền ưu đãi không giới hạn!"
        android:textSize="15sp"
        android:textColor="#616161"
        android:gravity="center"
        android:layout_marginTop="12dp"
        android:lineSpacingExtra="4dp"/>

    <androidx.appcompat.widget.AppCompatButton
        android:id="@+id/btnPremium"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:layout_marginTop="24dp"
        android:background="@drawable/bg_button_solid"
        android:text="MUA XU NGAY"
        android:textColor="#FFFFFF"
        android:textStyle="bold"
        android:drawableEnd="@drawable/icon_kcuong"
        app:drawableTint="#FFFFFF"
        android:paddingEnd="16dp"
        android:paddingStart="16dp"/>

    <androidx.appcompat.widget.AppCompatButton
        android:id="@+id/btnContinue"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:layout_marginTop="12dp"
        android:background="@drawable/bg_button_outline"
        android:text="XEM VIDEO NHẬN QUÀ"
        android:textColor="#FF5722"
        android:textStyle="bold"
        android:drawableEnd="@drawable/icon_video"
        app:drawableTint="#FF5722"
        android:paddingEnd="16dp"
        android:paddingStart="16dp"/>

</LinearLayout>
</FrameLayout>